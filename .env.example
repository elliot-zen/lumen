LUMEN_DATABASE_URL=postgresql+psycopg://lumen:lumen@localhost:5432/lumen
LUMEN_OBSIDIAN_CLI_COMMAND=/home/elliot/.local/bin/obsidian
LUMEN_OBSIDIAN_VAULT_NAME=moon

# Optional for local-file fallback adapter mode. Not required when using vault name + CLI.
LUMEN_OBSIDIAN_VAULT_ROOT=./tmp/obsidian-vault

LUMEN_SUMMARIZER_BASE_URL=
LUMEN_SUMMARIZER_API_KEY=replace-me
LUMEN_SUMMARIZER_MODEL=Qwen3.6-35B-A3B
LUMEN_SUMMARIZER_TIMEOUT_SECONDS=30.0
LUMEN_SUMMARIZER_VERIFY_SSL=false
# Optional alternative to disabling verification:
# LUMEN_SUMMARIZER_CA_BUNDLE=/path/to/your/ca.pem
